# App
APP_ENV=development
DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=maiz

# Auth (must match your Node server JWT settings)
JWT_SECRET=replace_with_same_secret_used_in_node_backend
JWT_ALGORITHM=HS256

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TIMEOUT_SECONDS=30

# Google Maps (for geocoding + directions)
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_MAPS_TIMEOUT_SECONDS=10

# MongoDB pool tuning
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=5
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Optional: if you keep media in cloud storage/CDN
MEDIA_BASE_URL=https://your-storage.com
